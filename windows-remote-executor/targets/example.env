# Copy this file to <name>.env and fill in the actual target details.

TARGET_NAME=win-lab
TARGET_HOST=100.101.102.103
TARGET_USER=Administrator
TARGET_PORT=22
TARGET_EXPECTED_LISTEN_ADDRESS=100.101.102.103
TARGET_EXPOSURE_MODE=private-only
TARGET_POLICY_LABEL='PRIVATE-ONLY TOKEN-REQUIRED'

# Optional: use a non-default SSH key.
# TARGET_KEY=/Users/you/.ssh/id_ed25519

# Optional but recommended: native commands will require this token once `win-remote policy`
# installs `access-policy.json` on the Windows host.
# TARGET_ACCESS_TOKEN=replace-with-a-random-token
#
# Public exposure is intentionally opt-in and should be explicitly labeled.
# TARGET_EXPOSURE_MODE=public-with-token
# TARGET_POLICY_LABEL='PUBLIC-WITH-TOKEN EXPLICIT'
#
# Optional: switch to pwsh if installed.
# TARGET_PS_EXE="C:/Program Files/PowerShell/7/pwsh.exe"

# Optional: override the default staging root used by `deploy`.
# TARGET_STAGE_ROOT=C:/CodexRemote/staging
